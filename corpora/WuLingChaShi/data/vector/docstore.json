ain", "start_char_idx": null, "end_char_idx": null, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e3d9d77c-78db-4146-9efe-62c538b09f8e": {"__data__": {"id_": "e3d9d77c-78db-4146-9efe-62c538b09f8e", "embedding": null, "metadata": {"file_name": "WuLingChaShi.txt", "section": "\u7b2c\u4e09\u7ae0 \u65b0\u8def", "subsection": "", "section_path": "\u7b2c\u4e09\u7ae0 \u65b0\u8def"}, "excluded_embed_metadata_keys": ["section_path"], "excluded_llm_metadata_keys": ["section_path"], "relationships": {}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u4e94\u6708\u521d\uff0c\u987e\u660e\u6f9c\u7b2c\u4e8c\u6b21\u6765\u5230\u96fe\u5cad\u6751\uff0c\u5e26\u6765\u4e86\u4e00\u4efd\u65b0\u7684\u5408\u4f5c\u65b9\u6848\uff1a\u6e05\u6e90\u8d44\u672c\u53ea\u6295\u4e00\u767e\u4e07\uff0c\u4e0d\u4e0a\u673a\u5668\uff0c\u4e0d\u6269\u4ea7\u91cf\uff0c\u8f6c\u800c\u505a\u9ad8\u7aef\u5b9a\u5236\u2014\u2014\u624b\u5de5\u8336\u9650\u91cf\u53d1\u552e\uff0c\u9648\u4f2f\u5e26\u516d\u4e2a\u5f92\u5f1f\uff0c\u628a\u624b\u827a\u4e00\u4ee3\u4ee3\u4f20\u4e0b\u53bb\u3002\n\u3000\u3000\"\u6211\u539f\u4ee5\u4e3a\u519c\u4e1a\u5c31\u662f\u89c4\u6a21\uff0c\"\u987e\u660e\u6f9c\u5bf9\u6c88\u9752\u79be\u8bf4\uff0c\"\u9648\u4f2f\u7684\u624b\u8ba9\u6211\u660e\u767d\uff0c\u6709\u4e9b\u4e1c\u897f\u7684\u4ef7\u503c\u6070\u6070\u5728\u4e8e\u5b83\u505a\u4e0d\u5feb\u3002\"\n\u3000\u3000\u6c88\u9752\u79be\u5728\u5408\u540c\u4e0a\u7b7e\u4e86\u5b57\u3002\u5f53\u5e74\u79cb\u5929\uff0c\u4e91\u5cad\u8336\u793e\u7684\u7b2c\u4e00\u6279\u5b9a\u5236\u8336\u5728\u7701\u57ce\u5356\u5230\u8131\u9500\uff0c\u8ba2\u5355\u6392\u5230\u4e86\u7b2c\u4e8c\u5e74\u6e05\u660e\u3002\u9648\u4f2f\u6536\u4e0b\u4e86\u7b2c\u4e00\u4e2a\u5f92\u5f1f\u2014\u2014\u6751\u91cc\u9ad8\u4e2d\u6bd5\u4e1a\u6ca1\u8d70\u51fa\u53bb\u7684\u59d1\u5a18\u6797\u5c0f\u6ee1\u3002\n\u3000\u3000\u51ac\u5929\u843d\u96ea\u7684\u65f6\u5019\uff0c\u6c88\u9752\u79be\u7ad9\u5728\u8336\u56ed\u8fb9\u7ed9\u5916\u